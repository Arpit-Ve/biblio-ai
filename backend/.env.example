# ============================================
# BIBLIO AI — Environment Variables
# ============================================

# Server
PORT=5000
NODE_ENV=development

# MongoDB — Get free cluster at mongodb.com/atlas
MONGODB_URI=mongodb+srv://<username>:<password>@cluster.mongodb.net/bibliodb

# JWT Secret — any long random string
JWT_SECRET=your_super_secret_jwt_key_change_this_in_production

# Google Gemini API — Free at aistudio.google.com
GEMINI_API_KEY=your_gemini_api_key_here

# Frontend URL (for CORS)
FRONTEND_URL=http://localhost:3000

# ============================================
# All other APIs used (Free Dictionary, Open Library) 
# require NO API KEY — they're completely free
# ============================================
